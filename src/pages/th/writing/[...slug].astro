---
import { getCollection } from "astro:content";
import WritingArticle from "../../../components/WritingArticle.astro";

export async function getStaticPaths() {
  const posts = await getCollection("writingTh", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<WritingArticle lang="th" post={post} />
