---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const dateFmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}`;

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Writing — Sharon Sethi" description="Plain-English writing on AI, from someone who builds with it.">
  <header class="bar">
    <div class="container bar__inner">
      <a class="brand" href="/"><span class="dot"></span>Sharon Sethi</a>
      <a class="bar__back" href="/#writing">&larr; Back</a>
    </div>
  </header>

  <main class="section">
    <div class="container wrap">
      <header class="head">
        <p class="mono">Writing</p>
        <h1>No jargon. Written like I'd explain it over coffee.</h1>
      </header>

      <ul class="wlist">
        {
          posts.map((p) => (
            <li>
              <a class="witem" href={`/writing/${p.id}`}>
                <span class="mono witem__date">{dateFmt(p.data.date)}</span>
                <span class="witem__body">
                  <span class="witem__title">{p.data.title}</span>
                  <span class="witem__hook">{p.data.hook}</span>
                </span>
                <span class="witem__arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <span class="mono">&copy; 2026 Sharon Sethi</span>
      <span class="mono">Built between code and storytelling</span>
    </div>
  </footer>
</Base>

<style>
  .bar {
    border-bottom: 1px solid var(--line);
    height: var(--header-h);
    display: flex;
    align-items: center;
  }
  .bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bar__back {
    font-size: 14px;
    color: var(--slate);
    text-decoration: none;
  }
  .bar__back:hover {
    color: var(--ink);
  }
  .wrap {
    max-width: 760px;
  }
  .head {
    padding-block: clamp(32px, 6vw, 64px) clamp(24px, 4vw, 40px);
  }
  .head h1 {
    margin-top: 16px;
    font-size: clamp(2rem, 5vw, 3rem);
    max-width: 20ch;
  }
  .wlist {
    list-style: none;
    padding: 0;
  }
  .witem {
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr) 28px;
    gap: 24px;
    align-items: baseline;
    padding-block: 26px;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.25s var(--ease);
  }
  .wlist li:last-child .witem {
    border-bottom: 1px solid var(--line);
  }
  @media (prefers-reduced-motion: no-preference) {
    .witem:hover {
      padding-left: 10px;
    }
  }
  .witem__date {
    padding-top: 6px;
  }
  .witem__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    letter-spacing: -0.015em;
  }
  .witem__hook {
    display: block;
    margin-top: 6px;
    color: var(--slate);
  }
  .witem__arrow {
    color: var(--slate);
    font-size: 18px;
    align-self: center;
  }
  .witem:hover .witem__arrow {
    color: var(--signal);
  }
  .site-footer {
    border-top: 1px solid var(--line);
    padding-block: 28px;
    margin-top: clamp(48px, 8vw, 96px);
  }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  @media (max-width: 520px) {
    .witem {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .witem__arrow {
      display: none;
    }
  }
</style>
