---
// Shared homepage content. The nav variant is passed in as a slot by each page,
// so all three comparison routes share identical body copy and layout.
import { getCollection } from "astro:content";
import WorkSection from "./WorkSection.astro";

// Latest writing — pulled from /content/writing/*.md, newest first, drafts hidden.
// Add a markdown file there to publish; nothing here needs to change.
const dateFmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}`;
// Social links — replace the # with your real profile URLs (that's the only edit needed).
const socials = [
  { label: "LinkedIn", href: "https://linkedin.com/in/sharon-sethi-eraya777" },
  { label: "GitHub", href: "https://github.com/sharonsara" },
  { label: "X", href: "https://x.com/sharonsara25" },
];

// inline icon paths (24x24 viewBox) so we ship no icon library
const icons: Record<string, string> = {
  LinkedIn:
    '<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.97 0 1.78-.78 1.78-1.74V1.74C24 .78 23.19 0 22.22 0z"/>',
  GitHub:
    '<path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.5.3.9 1 .9 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"/>',
  X: '<path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.15h7.6l5.24 6.93 6.06-6.93zm-1.29 19.5h2.04L6.48 3.24H4.3L17.61 20.65z"/>',
};

const writing = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => ({
    href: `/writing/${p.id}`,
    date: dateFmt(p.data.date),
    title: p.data.title,
    hook: p.data.hook,
  }));

const experiments = [
  {
    tag: "AGENTS",
    title: "Building a 5-agent research crew with the Claude Agent SDK",
    takeaway:
      "Splitting one big prompt into specialised agents cut my error rate hard. Here's when orchestration actually beats a single model — and when it's just overhead.",
    featured: true,
  },
  {
    tag: "COMPUTER USE",
    title: "I let a model drive my browser for a week",
    takeaway:
      "Promising, not magic. It nailed repetitive forms and fell apart on anything ambiguous. A plain-English guide to where it helps today.",
  },
  {
    tag: "VOICE",
    title: "Real-time voice agents that don't sound like robots",
    takeaway:
      "Latency is the whole game. What I changed to get a back-and-forth that feels like a phone call, not a walkie-talkie.",
  },
  {
    tag: "RAG",
    title: "Why my first RAG setup lied with total confidence",
    takeaway:
      "Retrieval was fine — the prompt wasn't. The two fixes that stopped the hallucinations, explained without the jargon.",
  },
];

---

<main>
  <!-- HERO -->
  <section id="home" class="section hero reveal">
    <div class="container hero__grid">
      <div class="hero__copy">
        <p class="mono hero__eyebrow">Agentic AI orchestrator</p>
        <h1 class="hero__title">
          I break in the newest AI tools, then translate them into
          <span class="hero__mark">plain English</span>.
        </h1>
        <p class="hero__sub">
          Half engineer, half creator. I orchestrate AI systems and write about
          what actually matters — so you don't have to decode the hype.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="#experiments">Read the experiments</a>
          <a class="btn btn--ghost" href="#writing">Browse the writing</a>
        </div>
      </div>

      <!-- signature asset: an orchestration "level" cluster, echoing the nav -->
      <div class="hero__signal" aria-hidden="true">
        <span style="--h: 38%"></span>
        <span style="--h: 72%"></span>
        <span style="--h: 54%" class="is-signal"></span>
        <span style="--h: 88%"></span>
        <span style="--h: 46%"></span>
        <span style="--h: 64%"></span>
      </div>
    </div>
  </section>

  <!-- EXPERIMENTS -->
  <section id="experiments" class="section block reveal">
    <div class="container">
      <header class="block__head">
        <h2>Selected experiments</h2>
        <p class="block__lead">
          Tools I've put real hours into, each with the one takeaway worth keeping.
        </p>
      </header>

      <div class="xgrid">
        {
          experiments.map((x) => (
            <article class={`xcard${x.featured ? " xcard--featured" : ""}`}>
              <p class="mono xcard__tag">{x.tag}</p>
              <h3 class="xcard__title">{x.title}</h3>
              <p class="xcard__takeaway">{x.takeaway}</p>
              <span class="xcard__more">Read the experiment &rarr;</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- WORK (videos made for company channel) -->
  <WorkSection />

  <!-- TRANSLATION STRIP -->
  <section id="translate" class="section strip reveal">
    <div class="container">
      <p class="strip__line">
        I translate AI from <em>engineer-speak</em> into language anyone can use.
      </p>
    </div>
  </section>

  <!-- WRITING -->
  <section id="writing" class="section block reveal">
    <div class="container">
      <header class="block__head">
        <h2>Latest writing</h2>
        <p class="block__lead">Short reads. No jargon. Written like I'd explain it over coffee.</p>
      </header>

      <ul class="wlist">
        {
          writing.map((p) => (
            <li>
              <a class="witem" href={p.href}>
                <span class="mono witem__date">{p.date}</span>
                <span class="witem__body">
                  <span class="witem__title">{p.title}</span>
                  <span class="witem__hook">{p.hook}</span>
                </span>
                <span class="witem__arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))
        }
      </ul>

      <a class="wlist__all" href="/writing">All writing &rarr;</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact reveal">
    <div class="container contact__inner">
      <h2 class="contact__title">Working on something with AI in it?</h2>
      <p class="contact__sub">
        I take on a few collaborations at a time. Tell me what you're building.
      </p>
      <a class="btn btn--primary" href="mailto:sharonsethi25@gmail.com">Email Sharon</a>

      <ul class="socials" aria-label="Sharon on social media">
        {
          socials.map((s) => (
            <li>
              <a
                class="socials__link"
                href={s.href}
                aria-label={s.label}
                target="_blank"
                rel="me noopener"
              >
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" set:html={icons[s.label]} />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <span class="mono">&copy; 2026 Sharon Sethi</span>
      <ul class="socials socials--sm" aria-label="Sharon on social media">
        {
          socials.map((s) => (
            <li>
              <a
                class="socials__link"
                href={s.href}
                aria-label={s.label}
                target="_blank"
                rel="me noopener"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" set:html={icons[s.label]} />
              </a>
            </li>
          ))
        }
      </ul>
      <span class="mono">Built between code and storytelling</span>
    </div>
  </footer>
</main>

<style>
  main {
    display: block;
  }

  /* ---------- HERO ---------- */
  .hero {
    padding-block: clamp(56px, 10vw, 104px) clamp(48px, 8vw, 88px);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 200px;
    align-items: center;
    gap: clamp(32px, 6vw, 72px);
  }
  .hero__eyebrow {
    margin-bottom: 22px;
  }
  .hero__title {
    font-size: clamp(2.6rem, 6.2vw, 4.6rem);
    max-width: 16ch;
  }
  .hero__mark {
    color: var(--signal);
    font-style: italic;
  }
  .hero__sub {
    margin-top: 24px;
    max-width: 46ch;
    color: var(--slate);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
  }
  .hero__cta {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  /* hero signal cluster — a small "mix" that rises on load */
  .hero__signal {
    height: 220px;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    justify-self: end;
  }
  .hero__signal span {
    width: 14px;
    height: var(--h);
    background: var(--line);
    border-radius: 7px;
    transform-origin: bottom;
  }
  .hero__signal span.is-signal {
    background: var(--signal);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__signal span {
      animation: grow 0.9s var(--ease) backwards;
    }
    .hero__signal span:nth-child(1) { animation-delay: 0.3s; }
    .hero__signal span:nth-child(2) { animation-delay: 0.38s; }
    .hero__signal span:nth-child(3) { animation-delay: 0.46s; }
    .hero__signal span:nth-child(4) { animation-delay: 0.54s; }
    .hero__signal span:nth-child(5) { animation-delay: 0.62s; }
    .hero__signal span:nth-child(6) { animation-delay: 0.7s; }
  }
  @keyframes grow {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }

  /* ---------- GENERIC BLOCK ---------- */
  .block {
    padding-block: clamp(48px, 8vw, 96px);
  }
  .block__head {
    max-width: 60ch;
    margin-bottom: clamp(32px, 5vw, 56px);
  }
  .block__head h2 {
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
  }
  .block__lead {
    margin-top: 14px;
    color: var(--slate);
    max-width: 52ch;
  }

  /* ---------- EXPERIMENTS (asymmetric signal-log, not equal cards) ---------- */
  .xgrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .xcard {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-surface);
    padding: clamp(22px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s var(--ease), border-color 0.25s ease;
  }
  .xcard:hover {
    border-color: var(--ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .xcard:hover {
      transform: translateY(-3px);
    }
  }
  .xcard--featured {
    grid-column: 1 / -1;
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .xcard--featured .xcard__tag {
    color: var(--signal);
  }
  .xcard--featured .xcard__takeaway {
    color: color-mix(in srgb, var(--paper) 78%, transparent);
  }
  .xcard__tag {
    margin-bottom: 16px;
  }
  .xcard__title {
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    letter-spacing: -0.015em;
  }
  .xcard--featured .xcard__title {
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    max-width: 18ch;
  }
  .xcard__takeaway {
    margin-top: 14px;
    color: var(--slate);
    max-width: 52ch;
    flex: 1;
  }
  .xcard__more {
    margin-top: 22px;
    font-size: 14px;
    font-weight: 500;
    color: var(--signal);
  }

  /* ---------- TRANSLATION STRIP ---------- */
  .strip {
    padding-block: clamp(40px, 7vw, 80px);
    border-block: 1px solid var(--line);
  }
  .strip__line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.6rem, 4vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    max-width: 22ch;
  }
  .strip__line em {
    color: var(--signal);
    font-style: italic;
  }

  /* ---------- WRITING (editorial list, sparse dividers) ---------- */
  .wlist {
    list-style: none;
    padding: 0;
  }
  .witem {
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr) 28px;
    gap: 24px;
    align-items: baseline;
    padding-block: 26px;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.25s var(--ease);
  }
  .wlist li:last-child .witem {
    border-bottom: 1px solid var(--line);
  }
  @media (prefers-reduced-motion: no-preference) {
    .witem:hover {
      padding-left: 10px;
    }
  }
  .witem__date {
    padding-top: 6px;
  }
  .witem__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    letter-spacing: -0.015em;
  }
  .witem__hook {
    display: block;
    margin-top: 6px;
    color: var(--slate);
  }
  .witem__arrow {
    color: var(--slate);
    font-size: 18px;
    align-self: center;
  }
  .witem:hover .witem__arrow {
    color: var(--signal);
  }
  .wlist__all {
    display: inline-block;
    margin-top: 28px;
    font-size: 15px;
    font-weight: 500;
    color: var(--signal);
    text-decoration: none;
  }
  .wlist__all:hover {
    text-decoration: underline;
  }

  /* ---------- CONTACT ---------- */
  .contact {
    padding-block: clamp(64px, 12vw, 140px);
  }
  .contact__inner {
    text-align: center;
  }
  .contact__title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    max-width: 18ch;
    margin-inline: auto;
  }
  .contact__sub {
    margin-top: 18px;
    margin-bottom: 32px;
    color: var(--slate);
    max-width: 44ch;
    margin-inline: auto;
  }

  /* ---------- SOCIALS ---------- */
  .socials {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 10px;
  }
  .contact .socials {
    margin-top: 32px;
    justify-content: center;
  }
  .socials__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--slate);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.18s var(--ease);
  }
  .socials__link svg {
    fill: currentColor;
  }
  .socials__link:hover {
    color: var(--signal);
    border-color: var(--signal);
  }
  @media (prefers-reduced-motion: no-preference) {
    .socials__link:hover {
      transform: translateY(-2px);
    }
  }
  .socials--sm .socials__link {
    width: 34px;
    height: 34px;
  }

  /* ---------- FOOTER ---------- */
  .site-footer {
    border-top: 1px solid var(--line);
    padding-block: 28px;
  }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 820px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__signal {
      height: 120px;
      justify-self: start;
    }
    .xgrid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .witem {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .witem__arrow {
      display: none;
    }
  }
</style>
